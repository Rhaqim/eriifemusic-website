# Spotify API credentials
# Get these from: https://developer.spotify.com/dashboard
# Create an app → copy Client ID and Client Secret

SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here

# Artist ID — from the artist's Spotify URL:
# https://open.spotify.com/artist/XXXXXXXXXXXXXXXXXXXXXXXX
#                                  ^^^^^^^^^^^^^^^^^^^^^^^^ this part
SPOTIFY_ARTIST_ID=your_artist_spotify_id_here

# EmailJS — for the "Write a Letter" form on the Letters page
# Sign up free at https://www.emailjs.com (200 emails/month free)
# Dashboard → Email Services → Add Service (Gmail/Outlook/etc.) → copy Service ID
# Dashboard → Email Templates → Create Template → copy Template ID
# Dashboard → Account → Public Key → copy it
# These are safe to expose publicly (they're designed for client-side use)
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here

